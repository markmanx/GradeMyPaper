FROM node:10.16.3-alpine

ARG REACT_APP_AUTH0_DOMAIN
ARG REACT_APP_AUTH0_CLIENT_ID
ARG REACT_APP_STRIPE_PUBLISHABLE_KEY
ARG REACT_APP_BASE_URL
ARG REACT_APP_GRAPHQL_ENDPOINT

WORKDIR /home/node/app
COPY . ./
RUN npm ci && REACT_APP_AUTH0_DOMAIN=$REACT_APP_AUTH0_DOMAIN REACT_APP_AUTH0_CLIENT_ID=$REACT_APP_AUTH0_CLIENT_ID REACT_APP_STRIPE_PUBLISHABLE_KEY=$REACT_APP_STRIPE_PUBLISHABLE_KEY REACT_APP_BASE_URL=$REACT_APP_BASE_URL REACT_APP_GRAPHQL_ENDPOINT=$REACT_APP_GRAPHQL_ENDPOINT npm run build
CMD npm run start:prod
