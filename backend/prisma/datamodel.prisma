type User {
  id: ID! @id
  email: String!
  stripeCustomerId: String
  auth0Id: String! @unique
  credits: Int!
}

enum Qualification {
  ALEVEL
  ASLEVEL
}

enum Board {
  AQA
}

type Paper {
  id: ID! @id
  paperId: String! @unique
  board: Board!
  title: String!
  qualification: Qualification!
  questionsUrl: String!
  markSchemeUrl: String!
}

type PageUpload {
  id: ID! @id
  order: Int!
  request: Request! @relation(link: INLINE)
}

type Request {
  id: ID! @id
  paymentRef: String
  paper: Paper! @relation(link: TABLE)
  pageUploads: [PageUpload!]!
}